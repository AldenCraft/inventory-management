# Client environment variables (Vite)
#
# Copy to `.env` (or `.env.local`) and adjust for your environment.
# Only variables prefixed with VITE_ are exposed to the client bundle.
#
# Base URL for the FastAPI backend, including the `/api` path.
# When unset, the app falls back to http://localhost:8001/api (local dev default).
# Set this for production builds so the deployed frontend reaches the real backend, e.g.:
#   VITE_API_BASE_URL=https://api.example.com/api
VITE_API_BASE_URL=http://localhost:8001/api
